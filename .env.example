# ItinerAI-Bench — environment variables
# Copy this file to .env and fill in your real keys. Never commit .env itself.

# ── Phase 1: Synthetic Data Generation ───────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here          # default provider (gpt-4o-mini)
GEMINI_API_KEY=your-gemini-key-here              # optional alternative provider
GROQ_API_KEY=your-groq-key-here                  # optional alternative provider

# ── Phase 2: Multi-Agent Pipeline ────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key-here          # default provider (deepseek-chat)

# ── MCP Servers ───────────────────────────────────────────────────────────────
ORS_API_KEY=your-openrouteservice-key-here       # OpenRouteService (routing_server.py)